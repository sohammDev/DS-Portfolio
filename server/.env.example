PORT=5000

# Local dev (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=portfolio_db

# Railway (set this on Railway dashboard — it will be auto-provided)
# DATABASE_URL=mysql://user:pass@host:port/dbname

# Your Vercel frontend URL (for CORS) — set this on Railway dashboard
FRONTEND_URL=https://your-app.vercel.app
